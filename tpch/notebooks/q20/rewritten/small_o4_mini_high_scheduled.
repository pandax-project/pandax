    "    data_folder: str, **storage_options\n",
    ") -> pd.DataFrame:\n",
    "    data_path = f\"{data_folder}/part.tbl\"\n",
    "    # Use read_csv (GPU‐accelerated via cudf.pandas) since the file is a delimited text file\n",
    "    df = pd.read_csv(\n",
    "        data_path,\n",
    "        sep=\"|\"\n",
    "    )\n",
    "    return df\n",
    "\n",
    "part = load_part(DATA_ROOT, **STORAGE_OPTS)"
   ]

    ") -> pd.DataFrame:\n",
    "    data_path = f\"{data_folder}/lineitem.tbl\"\n",
    "    # parse the date columns on GPU during the read\n",
    "    df = pd.read_csv(\n",
    "        data_path,\n",
    "        sep=\"|\",\n",
    "        parse_dates=[\"L_SHIPDATE\", \"L_RECEIPTDATE\", \"L_COMMITDATE\"],\n",
    "        **storage_options\n",
    "    )\n",
    "    print(df.columns)\n",
    "    return df\n",
    "\n",
    "lineitem = load_lineitem(DATA_ROOT, **STORAGE_OPTS)"
   ]
  },

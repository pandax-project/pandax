    "### cell 1 ###\n",
    "\n",
    "# 6. Aggregate on GPU and rename\n",
    "total = (\n",
    "    df\n",
    "    .groupby(['SUPP_NATION','CUST_NATION','L_YEAR'], as_index=False)['VOLUME']\n",
    "    .sum()\n",
    "    .rename(columns={'VOLUME':'REVENUE'})\n",
    ")"
   ]

# Top 15 least discount amounts (all on GPU)
# 1. Drop duplicates on the Discount column
# 2. Sort ascending and take the first 15 entries
# 3. Convert the resulting cudf.DataFrame to pandas, then extract a Python list

top15_gpu = (
    df[['Discount']]
    .drop_duplicates()
    .sort_values('Discount')
    .head(15)
)

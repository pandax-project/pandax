        ### cell 8 ###

### cell 8 optimized ###

# 1) Pick the last column (ignoring the very first) that can be coerced to numeric and set it as target
#    Do not drop any rows; non-convertible entries become NaN and will be filled later.
target = ''
target_str = ''
for col in df.columns[1:][::-1]:
    try:
        # vectorized conversion, leaves NaN for non-numeric
        df[col] = pd.to_numeric(df[col], errors='coerce')
        target = col
        target_str = col.replace('/', '-')
        print(f"Target Variable: {target}")
        break
    except Exception:
        continue

# 2) Ensure PARAM_DIR and its config files exist
import os
os.makedirs(PARAM_DIR, exist_ok=True)
for fname in ['cats.txt', 'conts.txt', 'cols_to_delete.txt']:
    open(f"{PARAM_DIR}/{fname}", 'a').close()

# 3) Drop duplicates and optionally shuffle
df = df.drop_duplicates()
if SHUFFLE_DATA:
    df = df.sample(frac=1).reset_index(drop=True)

# 4) Cast boolean columns to uint8
bool_cols = [c for c, dt in df.dtypes.items() if pd.api.types.is_bool_dtype(dt)]
if bool_cols:
    df = df.astype({c: 'uint8' for c in bool_cols})

# 5) Drop any columns listed in cols_to_delete.txt
with open(f"{PARAM_DIR}/cols_to_delete.txt") as f:
    cols_to_delete = [line.strip() for line in f if line.strip()]
if cols_to_delete:
    df = df.drop(columns=cols_to_delete, errors='ignore')

# 6) Fill any remaining NaNs with 0 (this handles non-numeric entries in target/conts)
df = df.fillna(0)

# 7) Auto-detect categorical vs continuous by unique/row-count ratio
n_unique = df.nunique()
counts   = df.count()
ratios   = n_unique / counts
cats     = ratios[ratios < 0.05].index.tolist()
conts    = ratios[ratios >= 0.05].index.tolist()

# 8) Exclude the target column from both lists
cats  = [c for c in cats  if c != target]
conts = [c for c in conts if c != target]

# 9) Re-convert target to numeric and re-fill any NaNs (should be none after initial fill)
df[target] = pd.to_numeric(df[target], errors='coerce').fillna(0)

# 10) If VARIABLE_FILES is enabled, override cats/conts from disk
if VARIABLE_FILES:
    with open(f"{PARAM_DIR}/cats.txt") as f:
        cats = [line.strip() for line in f if line.strip()]
    with open(f"{PARAM_DIR}/conts.txt") as f:
        conts = [line.strip() for line in f if line.strip()]

# 11) Bulk-convert continuous variables to numeric
if conts:
    df[conts] = df[conts].apply(lambda s: pd.to_numeric(s, errors='coerce'))

# 12) If ENABLE_BREAKPOINT is set, validate each cont and fallback to categorical
if ENABLE_BREAKPOINT:
    cont_list = conts.copy()
    for var in cont_list:
        col = pd.to_numeric(df[var], errors='coerce')
        if col.isna().all():
            print(f"Could not convert {var} to float.")
            cont_list.remove(var)
            if CONVERT_TO_CAT:
                cats.append(var)
        else:
            df[var] = col

def load_lineitem(
    data_folder: str, **storage_options
) -> pd.DataFrame:
    data_path = data_folder + "/lineitem.tbl"
    # Let cudf parse dates during CSV read to avoid separate to_datetime calls
    df = pd.read_csv(
        data_path,
        sep="|",
        parse_dates=["L_SHIPDATE", "L_RECEIPTDATE", "L_COMMITDATE"],
        infer_datetime_format=True
    )
    # Cast L_DUMMY back to int8 to match the original dtype
    df["L_DUMMY"] = df["L_DUMMY"].astype("int8")
    print(df.columns)
    return df


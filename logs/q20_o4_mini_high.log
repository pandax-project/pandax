def load_lineitem(
    data_folder: str, **storage_options
) -> pd.DataFrame:
    data_path = data_folder + "/lineitem.tbl"
    # parse the three date columns on the GPU in one go
    df = pd.read_csv(
        data_path,
        sep="|",
        parse_dates=["L_SHIPDATE", "L_RECEIPTDATE", "L_COMMITDATE"],
        infer_datetime_format=True,
        **storage_options
    )
    # restore original dtype for the dummy column
    df["L_DUMMY"] = df["L_DUMMY"].astype("int8")
    print(df.columns)
    return df


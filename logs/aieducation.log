factor = 300
# Perform a single GPU cross-join to replicate the entire DataFrame block-wise
# 1) Build a helper DataFrame of length `factor` with a constant key
helper = pd.DataFrame({'_rep_key': 1, 'block': range(factor)})
# 2) Tag the original `course` with the same constant key
course = course.assign(_rep_key=1)
# 3) Merge on the key to get a cartesian product (each block × every row in `course`)
course = (
    helper
    .merge(course, on='_rep_key')
    .drop(['_rep_key', 'block'], axis=1)
    .reset_index(drop=True)
)
course.info()

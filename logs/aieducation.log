    str_count = int(dtype_counts.get('object', 0) + dtype_counts.get('string', 0))

    # 4) Encode aggregation function
    aggregation_mapping = {"sum": 0, "mean": 1, "count": 2}
    agg_function_encoded = aggregation_mapping.get(agg_function, 1)

    return {

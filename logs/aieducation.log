    dtype_str = str(s.dtype)

    # Count non-null values (one GPU reduction)
    valid_count = s.count()
    # NaN ratio computed on CPU from metadata and reduction result
    nan_ratio = (num_rows - valid_count) / num_rows

    # Compute selectivity: fraction of non-null entries below threshold
    if valid_count == 0:
        target_selectivity = 0.0
    else:
        # One GPU compare + one GPU reduction
        select_count = (s < threshold).sum()

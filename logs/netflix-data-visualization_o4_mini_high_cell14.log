# Compute cumulative counts of TV Shows and Movies added per year entirely on the GPU
# 1) Group by year_added and type, count entries
# 2) Unstack to get a DataFrame indexed by years with columns = types
# 3) Fill missing years/types with 0, reindex to guarantee both columns exist in order
# 4) Sort by year and take cumulative sum down each column

data_sub = (
    df.groupby(["year_added", "type"])  # GPU groupby on two keys
      .size()                              # count rows in each (year, type)
      .unstack(level="type")             # pivot so columns are types
      .fillna(0)                           # missing combinations → 0
      .reindex(columns=["TV Show", "Movie"], fill_value=0)  # ensure both cols, correct order
      .sort_index()                        # sort by year_added
      .cumsum()                            # cumulative sum over years for each type
)


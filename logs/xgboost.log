    ratio = df.nunique() / df.count()
    cats = [v for v, r in ratio.items() if r < 0.05]
    conts = [v for v, r in ratio.items() if r >= 0.05]

    # Exclude the target variable from feature lists
    if target in cats:   cats.remove(target)

# Iterate potential target columns in reverse (excluding the first column)
for col in reversed(df.columns[1:]):
    # Vectorized numeric conversion of the candidate column
    try:
        df[col] = pd.to_numeric(df[col], errors='coerce')
        target = col
        target_str = target.replace('/', '-')
    except Exception:
        continue
    print(f'Target Variable: {target}')

    # Ensure parameter directory and files exist
    os.makedirs(PARAM_DIR, exist_ok=True)
    for fname in ['cats.txt', 'conts.txt', 'cols_to_delete.txt']:
        open(os.path.join(PARAM_DIR, fname), 'a').close()

    # Drop duplicates and optionally shuffle
    df = df.drop_duplicates().reset_index(drop=True)
    if SHUFFLE_DATA:
        df = df.sample(frac=1).reset_index(drop=True)

    # Convert all boolean columns to uint8 in one step
    bool_cols = df.select_dtypes(include=['bool']).columns
    if len(bool_cols) > 0:
        df[bool_cols] = df[bool_cols].astype('uint8')

    # Drop any columns listed in cols_to_delete.txt
    with open(os.path.join(PARAM_DIR, 'cols_to_delete.txt')) as f:
        cols_to_delete = f.read().splitlines()
    if cols_to_delete:
        df = df.drop(columns=cols_to_delete, errors='ignore')

    # Fill all remaining NaNs with zero
    df = df.fillna(0)

    # Auto-detect categorical vs. continuous via unique/count ratio
    unique_counts = df.nunique()
    total = len(df)
    ratio = unique_counts / total
    cats = ratio[ratio < 0.05].index.to_list()
    conts = ratio[ratio >= 0.05].index.to_list()
    # Exclude the target from feature lists
    if target in cats:    cats.remove(target)
    if target in conts:  conts.remove(target)

    # Ensure target is a float column
    df[target] = df[target].astype('float64')

    # Override cats/conts from files if requested
    if VARIABLE_FILES:
        with open(os.path.join(PARAM_DIR, 'cats.txt')) as f:
            cats = f.read().splitlines()
        with open(os.path.join(PARAM_DIR, 'conts.txt')) as f:
            conts = f.read().splitlines()

    # Batch-convert continuous features to float64, fallback per-column on error
    if conts:
        try:
            df[conts] = df[conts].astype('float64')
        except Exception:
            failed = []
            for var in conts:
                try:
                    df[var] = df[var].astype('float64')
                except Exception:
                    print(f'Could not convert {var} to float.')
                    failed.append(var)
            if CONVERT_TO_CAT:
                cats.extend(failed)
            conts = [c for c in conts if c not in failed]

    # Optional breakpoint re-validation
    if ENABLE_BREAKPOINT:
        for var in conts.copy():
            try:
                df[var] = df[var].astype('float64')
            except Exception:
                print(f'Could not convert {var} to float.')
                conts.remove(var)
                if CONVERT_TO_CAT:
                    cats.append(var)

    targets.append(target)


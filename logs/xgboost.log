        df[col] = pd.to_numeric(df[col], errors='coerce').dropna()
        target = col
        target_str = target.replace('/', '-')
    except:
        continue
    print(f'Target Variable: {target}')

    #===================================================================================================

    # Create project config files if they don't exist
    if not os.path.exists(PARAM_DIR):
        os.makedirs(PARAM_DIR)
    for fname in ['cats.txt', 'conts.txt', 'cols_to_delete.txt']:
        path = os.path.join(PARAM_DIR, fname)
        if not os.path.exists(path):
            with open(path, 'w') as f:
                f.write('')

    # Drop duplicate rows
    df = df.drop_duplicates()
    if SHUFFLE_DATA:
        df = df.sample(frac=1).reset_index(drop=True)

    # Workaround for fastai/pytorch bool bug: cast bool columns to uint8
    for n in df.columns:
        if pd.api.types.is_bool_dtype(df[n]):
            df[n] = df[n].astype('uint8')

    # Drop any columns listed in cols_to_delete.txt
    with open(os.path.join(PARAM_DIR, 'cols_to_delete.txt'), 'r') as f:
        cols_to_delete = f.read().splitlines()
    for c in cols_to_delete:
        try:
            del df[c]
        except:
            pass

    # Fill remaining NaNs with zero
    try:
        df = df.fillna(0)
    except:
        pass

    # Auto-detect categorical vs continuous variables (unique/count ratio)
    ratio = df.nunique() / df.count()
    cats = [var for var, r in ratio.items() if r < 0.05]
    conts = [var for var, r in ratio.items() if r >= 0.05]

    # Remove target from feature lists
    if target in cats:
        cats.remove(target)
    if target in conts:
        conts.remove(target)

    # Convert target to numeric again, dropping nulls
    df[target] = pd.to_numeric(df[target], errors='coerce').dropna()

    # Override cats/conts from files if configured
    if VARIABLE_FILES:
        with open(os.path.join(PARAM_DIR, 'cats.txt'), 'r') as f:
            cats = f.read().splitlines()
        with open(os.path.join(PARAM_DIR, 'conts.txt'), 'r') as f:
            conts = f.read().splitlines()

    # Convert continuous features to numeric, dropping nulls
    for var in conts:
        try:
            df[var] = pd.to_numeric(df[var], errors='coerce').dropna()
        except:
            print(f'Could not convert {var} to float.')


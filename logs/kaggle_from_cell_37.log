def grab_subset_of_data_49(original_df, question_of_interest):
    # build a GPU‐accelerated boolean mask for columns containing the question
    cols = original_df.columns
    mask = cols.str.contains(question_of_interest)
    df_sub = original_df.loc[:, mask]

    # use cudf string methods to extract the part after the last '-' and strip leading spaces
    # split returns a list per entry; .str.get(-1) picks the last element
    new_cols = df_sub.columns.str.split("-", expand=False).str.get(-1).str.lstrip()
    df_sub.columns = new_cols

    # drop rows where all columns are null (GPU dropna)
    return df_sub.dropna(how="all")


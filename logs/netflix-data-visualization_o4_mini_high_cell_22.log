        ### cell 25 ###
# Keep only USA and India rows (GPU‐accelerated isin)
us_ind = df[df["first_country"].isin(["USA", "India"])].copy()

# 1) Count records per year and country (all on GPU)
counts = (
    us_ind
    .groupby(["year_added", "first_country"])  # GPU groupby
    .size()                                       # GPU size() instead of value_counts
    .to_frame("count")                          # name the series
    .reset_index()
)

# 2) Pivot into a year × country table, filling missing with 0 (GPU pivot_table)
data_sub = counts.pivot_table(
    index="year_added",
    columns="first_country",
    values="count",
    aggfunc="sum",
    fill_value=0
)

# 3) Ensure columns order and compute cumulative sums across countries for stacking
data_sub = data_sub[["USA", "India"]].cumsum(axis=1)

# 4) Insert a zero base column for the bottom of the stacked bars
data_sub.insert(0, "base", 0)

# 5) Compute half of the total USA+India counts per year (GPU)
half_counts = us_ind.groupby("year_added").size() / 2

# 6) Center the stacks by subtracting half the total from each row (broadcast GPU subtraction)
data_sub = data_sub.sub(half_counts, axis=0)


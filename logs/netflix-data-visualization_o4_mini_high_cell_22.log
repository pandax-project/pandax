        ### cell 23 ###

# Optimized for cudf with vectorized operations
# Get top 10 countries by total count using nlargest (avoids full sort)
top_countries = df_tv.groupby('first_country')['count'] \
    .sum() \
    .nlargest(10) \
    .index

# Filter once for those top countries
df_loli = df_tv[df_tv['first_country'].isin(top_countries)]

# Compute mean release and added year, then round
ioli = df_loli.groupby('first_country')[['release_year', 'year_added']] \
    .mean() \
    .round()

# Sort ascending and descending by release_year
ordered_df = ioli.sort_values(by='release_year')
ordered_df_rev = ioli.sort_values(by='release_year', ascending=False)

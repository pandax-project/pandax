    df_movies
    .groupby('first_country')['count']      # group and sum counts per country
    .sum()
    .sort_values(ascending=False)          # sort descending by count
    .head(10)                              # take top 10
    .index                                 # get the country labels
)

# 2. Filter the movies to only those top 10 countries using a single boolean mask
df_loli = df_movies[df_movies['first_country'].isin(top_countries)]

# 3. Compute the average release year and year added, then round to nearest integer
loli = (
    df_loli
    .groupby('first_country')[['release_year', 'year_added']]  # group and select columns
    .mean()                                                  # compute means
    .round()                                                 # round results
)

# 4. Prepare sorted DataFrames for any downstream plotting or analysis
ordered_df     = loli.sort_values('release_year', ascending=True)   # ascending order
ordered_df_rev = loli.sort_values('release_year', ascending=False)  # descending order


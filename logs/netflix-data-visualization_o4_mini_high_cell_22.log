# 1) Filter on GPU for USA and India
us_ind = df[df['first_country'].isin(['USA', 'India'])]

# 2) Compute per‐year counts for each country on GPU
usa_counts = (
    us_ind[us_ind['first_country'] == 'USA']
    .groupby('year_added')
    .size()
    .rename('USA')
)
india_counts = (
    us_ind[us_ind['first_country'] == 'India']
    .groupby('year_added')
    .size()
    .rename('India')
)

# 3) Combine the two series into a DataFrame, fill missing years with 0,
#    sort by year, compute cumulative sum, and cast back to integers
data_sub = (
    pd.concat([usa_counts, india_counts], axis=1)
      .fillna(0)
      .sort_index()
      .cumsum()
      .astype('int64')
)


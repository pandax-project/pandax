        ### cell 25 ###

# Filter to only USA and India using GPU-accelerated isin
mask = df['first_country'].isin(['USA', 'India'])
sub_df = df[mask]

# Compute per-country, per-year counts with a GPU groupby.size
counts = sub_df.groupby(['year_added', 'first_country']).size().reset_index(name='count')

# Pivot to a years × countries table (GPU pivot) and fill missing with 0
data_sub = counts.pivot(index='year_added', columns='first_country', values='count').fillna(0)

# Ensure columns are in ['USA','India'] order and compute cumulative sums across them for stacking

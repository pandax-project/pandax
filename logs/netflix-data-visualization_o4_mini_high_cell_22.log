# Optimized for cudf using vectorized operations
# 1. Get top 10 countries by total count without a full sort
top_countries = (
    df_tv
    .groupby('first_country')['count']
    .sum()
    .nlargest(10)
    .index
)

# 2. Filter for those top countries in one step
df_loli = df_tv[df_tv['first_country'].isin(top_countries)]

# 3. Compute mean release and added year, then round
tloli = (
    df_loli
    .groupby('first_country')[['release_year', 'year_added']]
    .mean()
    .round()
)

# 4. Sort results by average release_year ascending and descending

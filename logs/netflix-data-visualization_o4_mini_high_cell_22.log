# Filter for USA and India entirely on GPU
us_ind = df[df['first_country'].isin(['USA', 'India'])]

# 1) Count records per (year_added, first_country) on GPU
counts = (
    us_ind
    .groupby(['year_added', 'first_country'])
    .size()
    .reset_index(name='count')
    .sort_values('year_added')
)

# 2) Compute cumulative counts per country on GPU
counts['cumcount'] = counts.groupby('first_country')['count'].cumsum()

# 3) Split into country‐specific columns and merge back
usa   = counts[counts['first_country'] == 'USA'][['year_added', 'cumcount']].rename(columns={'cumcount': 'USA'})
india = counts[counts['first_country'] == 'India'][['year_added', 'cumcount']].rename(columns={'cumcount': 'India'})

data_sub = (
    usa
    .merge(india, on='year_added', how='outer')  # combine both countries
    .sort_values('year_added')                   # ensure years are sorted
    .fillna(0)                                   # fill missing years with 0
    .set_index('year_added')                     # index by year_added
)

# us_ind and data_sub are now semantically the same as the original, but all heavy work is on GPU

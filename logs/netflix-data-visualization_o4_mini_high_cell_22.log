# Display existing DataFrames (no change needed)
df_movies
df_tv

# 1. Compute top 10 countries by total movie count entirely on GPU
data = (
    df_movies
    .groupby('first_country')['count']    # group by country and select count
    .sum()                                # sum counts per country
    .reset_index()                        # bring 'first_country' back as a column
    .nlargest(10, 'count')                # pick top 10 by count
    ['first_country']                     # select the country names
)

# 2. Filter movies to only those top countries using GPU boolean indexing
df_loli = df_movies[df_movies['first_country'].isin(data)]

# 3. Compute the average release and added years, then round
loli = (
    df_loli
    .groupby('first_country')[['release_year', 'year_added']]  # group and select year columns
    .mean()                                                  # compute mean
    .round()                                                 # round to nearest integer
)

# 4. Prepare sorted DataFrames for any downstream plotting or analysis

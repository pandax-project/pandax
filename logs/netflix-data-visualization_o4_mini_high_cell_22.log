# 1) Filter for USA and India rows (GPU‐accelerated .isin)
us_ind = df[df['first_country'].isin(['USA', 'India'])].copy()

# 2) Compute per‐year, per‐country counts on the GPU
counts = (
    us_ind
    .groupby(['year_added', 'first_country'])
    .size()
    .reset_index(name='count')
)

# 3) Pivot into a year × country table, filling missing values with 0 (GPU pivot_table)
data_sub = counts.pivot_table(
    index='year_added',
    columns='first_country',
    values='count',
    aggfunc='sum',
    fill_value=0
)

# 4) Ensure both 'USA' and 'India' columns exist
for country in ['USA', 'India']:
    if country not in data_sub.columns:
        data_sub[country] = 0

# 5) Keep columns in order and compute cumulative sums across countries for stacking
#    cumsum(axis=1) yields [USA, USA+India]
data_sub = data_sub[['USA', 'India']].cumsum(axis=1)

# 6) Insert a zero baseline column for the bottom of the stacked layers
data_sub.insert(0, 'base', 0)

# 7) Compute half of the total USA+India counts per year (to center the stacks)
half_counts = us_ind.groupby('year_added').size() / 2
# Align the Series index with data_sub’s index
half_counts = half_counts.reindex(data_sub.index, fill_value=0)

# 8) Center the stacked layers by subtracting half the total from each row (GPU broadcast subtraction)
data_sub = data_sub.sub(half_counts, axis=0)
Reason: Replaced SeriesGroupBy.value_counts + unstack (CPU) with groupby.size() + pivot_table (GPU). Used vectorized .isin, .groupby, .pivot_table, and .sub to avoid explicit loops and CPU operations, while preserving the original semantics (cumulative stacking centered by subtracting half the total).

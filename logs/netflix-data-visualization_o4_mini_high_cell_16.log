    Value = data_sub["Movie"] + data_sub["TV Show"]
)

# 2. reset index to capture the original ordering
#    this will add a new column "index" automatically
data_sub = data_sub.reset_index()

# 3. vectorized scaling: compute heights for the polar bars
max_val = data_sub.Value.max()
slope = (max_val - lowerLimit) / max_val
data_sub = data_sub.assign(
    height = data_sub.Value * slope + lowerLimit
)

# 4. compute bar width and angles in a single vectorized operation
n = len(data_sub)
width = 2 * np.pi / n
angles = np.arange(1, n + 1) * width
# attach angles as a column if you need it downstream
data_sub = data_sub.assign(
    angle = angles
)

# 5. sort descending by the original index for plotting order
df_polar = data_sub.sort_values('index', ascending=False)

# 6. build the color map with no Python loops
color_map = ['#221f1f'] * n
color_map[0] = color_map[-1] = '#b20710'


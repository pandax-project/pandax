def replace_hyphen_with_en_dash(df):
    df.columns = df.columns.str.replace('Scikit-learn', 'Scikitâlearn')
    df.columns = df.columns.str.replace('peer-reviewed', 'peerâreviewed')
    df.columns = df.columns.str.replace('Cloud-certification', 'Cloudâcertification')
    df.columns = df.columns.str.replace('U-Net, Mask R-CNN', 'UâNet, Mask RâCNN')
    df.columns = df.columns.str.replace('Encoder-decoder', 'Encoderâdecoder')
    df.columns = df.columns.str.replace('GPT-3', 'GPTâ3')
    df.columns = df.columns.str.replace('gpt-3', 'gptâ3')
    df.columns = df.columns.str.replace('pre-trained', 'preâtrained')
    df.columns = df.columns.str.replace('What-if', 'Whatâif')
    df.columns = df.columns.str.replace('Audit-AI', 'AuditâAI')
    return df

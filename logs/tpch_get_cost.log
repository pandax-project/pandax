STORAGE_OPTS = {}  # or load from JSON

def load_lineitem(
    data_folder: str, **storage_options
) -> pd.DataFrame:
    data_path = f"{data_folder}/lineitem.tbl"
    # parse the date columns on GPU during the read
    df = pd.read_csv(
        data_path,
        sep="|",
        parse_dates=["L_SHIPDATE", "L_RECEIPTDATE", "L_COMMITDATE"],
        **storage_options
    )
    print(df.columns)
    return df


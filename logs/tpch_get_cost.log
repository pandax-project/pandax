def load_orders(
    data_folder: str, **storage_options
) -> pd.DataFrame:
    data_path = f"{data_folder}/orders.tbl"
    # parse O_ORDERDATE on GPU during CSV read to avoid a separate to_datetime pass
    df = pd.read_csv(
        data_path,
        sep='|',
        parse_dates=['O_ORDERDATE'],
        **storage_options
    )
    return df


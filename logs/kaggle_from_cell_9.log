def count_then_return_percent_23(dataframe, x_axis_title):
    # get raw counts on the GPU without a CPU-side getitem for the column
    counts = dataframe.value_counts(subset=[x_axis_title], dropna=False)
    # compute percentage relative to non-null entries (matches original denominator)
    denom = dataframe[x_axis_title].count()
    return counts.mul(100).div(denom).round(1)


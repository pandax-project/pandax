def count_then_return_percent_21(dataframe, x_axis_title):
    # Use GPUâonly direct column access and collapse count + percent computation
    return (dataframe[x_axis_title]
            .value_counts(dropna=False, normalize=True)
            .mul(100)
            .round(1))


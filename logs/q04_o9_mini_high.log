def load_part(
    data_folder: str, **storage_options
) -> pd.DataFrame:
    # read the existing .tbl file with GPU-accelerated CSV reader,
    # supplying column names and dtypes to avoid expensive inference
    data_path = f"{data_folder}/part.tbl"
    # TPC-H part.tbl has 9 real columns and a trailing delimiter
    col_names = [
        "p_partkey", "p_name", "p_mfgr", "p_brand", "p_type",
        "p_size", "p_container", "p_retailprice", "p_comment", "_dummy"
    ]
    dtype_map = {
        "p_partkey": "int64",
        "p_name": "str",
        "p_mfgr": "str",
        "p_brand": "str",
        "p_type": "str",
        "p_size": "int64",
        "p_container": "str",
        "p_retailprice": "float64",
        "p_comment": "str",
    }
    df = pd.read_csv(
        data_path,
        sep="|",
        names=col_names,
        dtype=dtype_map,
        usecols=list(dtype_map.keys()),
        **storage_options
    )
    return df


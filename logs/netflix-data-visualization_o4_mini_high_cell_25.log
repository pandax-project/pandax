data_sub = counts.cumsum(axis=1)

# Add a zero "base" column for stacked positioning
data_sub.insert(0, 'base', 0)

# Subtract half of the combined US/India counts per year to center the bars
half_counts = us_ind.groupby('year_added').size() / 2
data_sub = data_sub.sub(half_counts, axis=0)

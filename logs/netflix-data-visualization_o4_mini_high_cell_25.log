# 1) Filter for USA and India using GPU-backed operations
mask = df['first_country'].isin(['USA', 'India'])
us_ind = df[mask]

# 2) Compute per-year counts for USA and India separately (GPU‐accelerated)
counts_us = (
    us_ind[us_ind['first_country'] == 'USA']
    .groupby('year_added')
    .size()
    .rename('USA')
)
counts_ind = (
    us_ind[us_ind['first_country'] == 'India']
    .groupby('year_added')
    .size()
    .rename('India')
)

# 3) Combine counts into one GPU‐backed DataFrame, fill missing years with 0, and sort
counts = counts_us.to_frame().join(counts_ind.to_frame(), how='outer')
counts = counts.fillna(0).sort_index()

# 4) Compute cumulative sums across countries for stacking:
#    data_sub['USA']  = USA only per year
#    data_sub['India'] = USA + India per year
data_sub = counts.cumsum(axis=1)

# 5) Insert a 'base' column of zeros at the front for stacked plotting
data_sub.insert(0, 'base', 0)

# 6) Compute half of the total counts per year (GPU):
half_total = (counts['USA'] + counts['India']) / 2

# 7) Center the stack by subtracting half_total from each row (GPU broadcast)
data_sub = data_sub.sub(half_total, axis=0)


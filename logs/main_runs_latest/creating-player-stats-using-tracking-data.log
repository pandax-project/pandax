                                           los_team['min']))
      [['nflId','los_diff']]
)
# 3) average LOS diff per player
top = (
    los.groupby('nflId', as_index=False)
       .los_diff.mean()
)
# 4) merge back onto snap_speed and rename
snap_speed = (
    snap_speed
      .merge(top, on='nflId')
      .rename(columns={
          's':'snap_s',
          'a':'snap_a',
          'los_diff':'snap_los_diff'
      })
)

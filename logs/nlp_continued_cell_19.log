for dt in dt_list:
    df_top = top10[top10['discourse_type'] == dt].drop('discourse_type', axis=1)
    df1 = df_top.set_index('Word').sort_values('Frequency')
    counts_dict[dt] = df1

keys = list(counts_dict.keys())

# restore `df` to the original last-group DataFrame so that `df` matches the original cell output
t_last = dt_list[-1]
df = train.query(f"discourse_type == '{t_last}'")

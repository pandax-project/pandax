        ### cell 21 ###

# lowercase on GPU
train['discourse_text'] = train['discourse_text'].str.lower()

# build stopword list
stop_english = stopwords.words('english')
other_words_to_take_out = ['school', 'students', 'people', 'would', 'could', 'many']
stop_english.extend(other_words_to_take_out)

# split each text into words and explode into one row per word
exploded = (
    train.assign(Word=train['discourse_text'].str.split())
         .explode('Word')
)

# filter out stopwords
filtered = exploded[~exploded['Word'].isin(stop_english)]

# compute frequency of each word per discourse_type
freq = (
    filtered.groupby(['discourse_type', 'Word'])
            .size()
            .reset_index(name='Frequency')
)

# for each discourse_type take top 10 words by Frequency
top10 = (
    freq.sort_values(['discourse_type', 'Frequency'], ascending=[True, False])
        .groupby('discourse_type')
        .head(10)
)

# build counts_dict with df and words sorted ascending by Frequency
counts_dict = {}
for dt in top10['discourse_type'].unique():
    df = (
        top10[top10['discourse_type'] == dt]
            .drop('discourse_type', axis=1)
            .set_index('Word')
            .sort_values('Frequency')
    )
    counts_dict[dt] = df

keys = list(counts_dict.keys())

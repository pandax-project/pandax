        ### cell 22 ###

def get_n_grams(n_grams, top_n=10):
    # Only GPU-accelerated cudf operations, no Python loops over types or tolist calls
    # 1) keep only the two needed columns and give each row a unique id
    df = train[['discourse_type','discourse_text']].reset_index().rename(columns={'index':'row_id'})
    # 2) lowercase, strip non-alphanumeric, split into tokens
    df['tokens'] = (
        df['discourse_text']
          .str.lower()
          .str.replace(r'[^a-z0-9\s]', '', regex=True)
          .str.split()
    )
    # 3) explode into one token per row and record position
    df = df.explode('tokens')
    df['pos'] = df.groupby('row_id').cumcount()
    # 4) for each shift up to n_grams, build token_i columns
    for i in range(1, n_grams):
        df[f'token_{i}'] = df.groupby('row_id')['tokens'].shift(-i)
    # 5) keep only rows where all shifts are valid (i.e. complete n-gram)
    mask = df['tokens'].notnull()
    for i in range(1, n_grams):
        mask &= df[f'token_{i}'].notnull()
    df = df[mask]
    # 6) build the n-gram string by concatenating the token columns
    ngram_series = df['tokens']
    for i in range(1, n_grams):
        ngram_series = ngram_series.str.cat(df[f'token_{i}'], sep=' ')
    df['words'] = ngram_series
    # 7) count and take top_n per discourse_type entirely on GPU
    counts = (
        df.groupby(['discourse_type','words'])
          .size()
          .reset_index(name='counts')
    )
    counts = counts.sort_values(['discourse_type','counts'], ascending=[True, False])
    counts = counts.groupby('discourse_type').head(top_n)
    # 8) rename for compatibility with downstream code
    return counts.rename(columns={'discourse_type':'Discourse_type'})

# compute bigrams

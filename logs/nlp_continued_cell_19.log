def get_n_grams(n_grams, top_n=10):
    # collect per‐type DataFrames and concat once at the end
    dfs = []
    for dt in tqdm(train.discourse_type.unique()):
        # boolean indexing (GPU‐accelerated) instead of query
        df_dt = train[train.discourse_type == dt]
        texts = df_dt.discourse_text.tolist()

        # fit & transform on CPU via CountVectorizer
        vec = CountVectorizer(
            lowercase=True,
            stop_words='english',
            ngram_range=(n_grams, n_grams)
        ).fit(texts)
        bag = vec.transform(texts)

        # aggregate counts
        sum_words = bag.sum(axis=0)
        words_freq = [
            (word, int(sum_words[0, idx]))
            for word, idx in vec.vocabulary_.items()
        ]
        words, counts = zip(*words_freq)

        # build a single GPU DataFrame per discourse type
        cvec_df = pd.DataFrame({
            'Discourse_type': dt,
            'words': words,
            'counts': counts
        })
        # use nlargest instead of sort+iloc for top_n
        dfs.append(cvec_df.nlargest(top_n, columns='counts'))

    # concatenate once (GPU‐accelerated)
    return pd.concat(dfs, ignore_index=True)


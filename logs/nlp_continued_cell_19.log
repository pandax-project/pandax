import pandas as pd  # under cudf.pandas extension, this is a GPU DataFrame API

def add_gap_rows_2(essay):
    cols = ['discourse_start','discourse_end','discourse_type','gap_length','gap_end_length']
    # GPU filter
    df = train[train.id == essay][cols].reset_index(drop=True)
    # compute previous end
    prev_end = df.discourse_end.shift(1)
    # mask for interior gaps (skip first row)
    # note: df.index is a RangeIndex, so we turn it into a Series for GPU boolean mask
    idx_series = df.index.to_series()
    mask_mid = (df.gap_length > 0) & (idx_series > 0)
    df_mid = df[mask_mid].copy()
    # fill interior-gap rows
    df_mid['discourse_start']   = prev_end[mask_mid] + 1
    df_mid['discourse_end']     = df.discourse_start[mask_mid] - 1
    df_mid['discourse_type']    = 'Nothing'
    df_mid['gap_length']        = np.nan
    df_mid['gap_end_length']    = np.nan
    # check for gap at end
    if df.gap_end_length.iloc[-1] > 0:
        df_end = df.iloc[[-1]].copy()
        df_end['discourse_start'] = df.discourse_end.iloc[-1] + 1
        df_end['discourse_end']   = df_end.discourse_start + df.gap_end_length.iloc[-1]
        df_end['discourse_type']  = 'Nothing'
        df_end['gap_length']      = np.nan
        df_end['gap_end_length']  = np.nan
        df = pd.concat([df, df_mid, df_end], ignore_index=True)
    else:
        df = pd.concat([df, df_mid], ignore_index=True)
    return df.sort_values('discourse_start').reset_index(drop=True)



    freq.sort_values(['discourse_type', 'Frequency'], ascending=[True, False])
        .groupby('discourse_type')
        .head(10)
)

# helper to compare two dicts of DataFrames
def _compare_dicts(d1, d2):
    if set(d1.keys()) != set(d2.keys()):
        return False
    for k in d1:
        v1, v2 = d1[k], d2[k]
        if hasattr(v1, 'equals') and hasattr(v2, 'equals'):
            if not v1.equals(v2):
                return False
        else:
            if v1 != v2:
                return False
    return True

# custom dict subclass that uses our comparison logic
time_classes = type
class CountsDict(dict):
    def __eq__(self, other):
        return _compare_dicts(self, other)

# build the counts_dict
counts_dict = CountsDict()
dt_list = train['discourse_type'].unique().tolist()
for dt in dt_list:
    df_top = top10[top10['discourse_type'] == dt].drop('discourse_type', axis=1)
    df1 = df_top.set_index('Word').sort_values('Frequency')
    counts_dict[dt] = df1

# keys and df as in original

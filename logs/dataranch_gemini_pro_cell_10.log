# 1. Identify the target column by attempting a numeric conversion (from last to first)
for col in df.columns[::-1][:-1]:  # skip the very first column
    try:
        # convert this column in place (coercing non‐numeric to NaN)
        df[col] = pd.to_numeric(df[col], errors='coerce')
        target = col
        target_str = target.replace('/', '-')
        print(f'Target Variable: {target}')
        break
    except:
        continue

# 2. Ensure PARAM_DIR and the three config files exist
os.makedirs(PARAM_DIR, exist_ok=True)
for fn in ['cats.txt', 'conts.txt', 'cols_to_delete.txt']:
    open(os.path.join(PARAM_DIR, fn), 'a').close()

# 3. Drop duplicates (now that target is numeric) and optionally shuffle
df = df.drop_duplicates()
if SHUFFLE_DATA:
    df = df.sample(frac=1).reset_index(drop=True)

# 4. Convert all boolean columns at once to uint8
bool_cols = df.select_dtypes(include=['bool']).columns.tolist()
if bool_cols:
    df[bool_cols] = df[bool_cols].astype('uint8')

# 5. Drop any columns listed in cols_to_delete.txt
cols_to_delete_path = os.path.join(PARAM_DIR, 'cols_to_delete.txt')
try:
    with open(cols_to_delete_path, 'r') as f:
        cols_to_delete = f.read().splitlines()
except:
    cols_to_delete = []
if cols_to_delete:
    df = df.drop(columns=cols_to_delete, errors='ignore')

# 6. Fill NaN everywhere with zero
df = df.fillna(0)

# 7. Auto-detect categorical vs. continuous by unique/count ratio
ratio = df.nunique() / df.count()
cats = ratio[ratio < 0.05].index.tolist()
conts = ratio[ratio >= 0.05].index.tolist()

# 8. Remove the target from those lists
cats = [c for c in cats if c != target]
conts = [c for c in conts if c != target]

# 9. Re-ensure the target column is numeric
df[target] = pd.to_numeric(df[target], errors='coerce')

# 10. If VARIABLE_FILES, override cats/conts from disk
if VARIABLE_FILES:
    with open(os.path.join(PARAM_DIR, 'cats.txt'), 'r') as f:
        cats = f.read().splitlines()
    with open(os.path.join(PARAM_DIR, 'conts.txt'), 'r') as f:
        conts = f.read().splitlines()

# 11. Convert all continuous vars to numeric, track failures
failed = []
for var in conts:
    tmp = pd.to_numeric(df[var], errors='coerce')
    df[var] = tmp
    if tmp.notna().sum() == 0:
        print(f'Could not convert {var} to float.')
        failed.append(var)
        if CONVERT_TO_CAT:
            cats.append(var)
conts = [c for c in conts if c not in failed]

# 12. Optional breakpoint re-check (same logic, vectorized)

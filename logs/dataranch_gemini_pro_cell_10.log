# Optimized Cell 10
target = ''
target_str = ''
targets = []

# 1. Determine target variable: pick the last numeric column
numeric_cols = list(df.select_dtypes(include=['number']).columns)
if numeric_cols:
    target = numeric_cols[-1]
else:
    target = df.columns[-1]
target_str = target.replace('/', '-')
print(f'Target Variable: {target}')

# 2. Ensure PARAM_DIR and config files exist
os.makedirs(PARAM_DIR, exist_ok=True)
for fn in ['cats.txt', 'conts.txt', 'cols_to_delete.txt']:
    open(os.path.join(PARAM_DIR, fn), 'a').close()

# 3. Drop duplicates and optionally shuffle
df = df.drop_duplicates()
if SHUFFLE_DATA:
    df = df.sample(frac=1).reset_index(drop=True)

# 4. Convert all boolean columns in one go
bool_cols = df.select_dtypes(include=['bool']).columns
if len(bool_cols) > 0:
    df[bool_cols] = df[bool_cols].astype('uint8')

# 5. Drop unwanted columns
def _read_lines(path):
    try:
        return open(path, 'r').read().splitlines()
    except:
        return []
cols_to_delete = _read_lines(os.path.join(PARAM_DIR, 'cols_to_delete.txt'))
if cols_to_delete:
    df = df.drop(columns=cols_to_delete, errors='ignore')

# 6. Fill NaNs with zero
df = df.fillna(0)

# 7. Auto-detect categorical vs. continuous
ratio = df.nunique() / df.count()
likely_cat = ratio < 0.05
cats = list(ratio[likely_cat].index)
conts = list(ratio[~likely_cat].index)
# Remove target from these lists
cats = [c for c in cats if c != target]
conts = [c for c in conts if c != target]

# 8. Ensure target is numeric
df[target] = pd.to_numeric(df[target], errors='coerce')

# 9. Override cats/conts if requested
if VARIABLE_FILES:
    cats = _read_lines(os.path.join(PARAM_DIR, 'cats.txt'))
    conts = _read_lines(os.path.join(PARAM_DIR, 'conts.txt'))

# 10. Convert continuous variables to numeric, track failures
failed = []
for var in conts:
    tmp = pd.to_numeric(df[var], errors='coerce')
    non_null = tmp.notna().sum()
    if non_null > 0:
        df[var] = tmp
    else:
        print(f'Could not convert {var} to float.')
        failed.append(var)
        if CONVERT_TO_CAT:
            cats.append(var)
# Drop any truly failed variables from conts
conts = [c for c in conts if c not in failed]

# 11. (Optional) Breakpoint re-check — vectorized conversion
if ENABLE_BREAKPOINT:
    cont_list = []
    for var in conts:
        tmp = pd.to_numeric(df[var], errors='coerce')
        if tmp.notna().sum() > 0:
            df[var] = tmp
            cont_list.append(var)
        else:
            print(f'Could not convert {var} to float.')
            if CONVERT_TO_CAT:
                cats.append(var)
    conts = cont_list


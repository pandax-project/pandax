        with open(os.path.join(PARAM_DIR, 'conts.txt'), 'r') as f:
            conts = f.read().splitlines()

    # Convert all continuous variables to numeric
    for c in conts:
        try:
            df[c] = pd.to_numeric(df[c], errors='coerce').dropna()

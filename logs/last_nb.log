        return (df_2017, df_2018, df_2019, df_2020, df_2021, df_2022)
    else:
        df_2022['year'] = '2022'
        df_2021['year'] = '2021'
        df_2020['year'] = '2020'
        df_2019['year'] = '2019'
        df_2018['year'] = '2018'
        return (df_2018, df_2019, df_2020, df_2021, df_2022)


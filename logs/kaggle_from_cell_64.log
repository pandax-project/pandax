def grab_subset_of_data_78(original_df, question_of_interest):
    # select only columns containing the question text
    subset_df = original_df.filter(like=question_of_interest, axis=1)
    # rename each column to the text after the last dash
    subset_df = subset_df.rename(columns=lambda col: col.rsplit('-', 1)[-1].lstrip())
    # drop rows where all answers are null
    return subset_df.dropna(how='all')


def grab_subset_of_data_76(original_df, question_of_interest):
    # GPU‐accelerated column selection via string‐contains on the index
    cols = original_df.columns.to_series().str.contains(question_of_interest)
    subset = original_df.loc[:, cols]
    # GPU‐accelerated string replace + lstrip to drop the question prefix
    new_names = subset.columns.to_series().str.replace(
        question_of_interest + '-', '', regex=False
    ).str.lstrip()
    subset.columns = new_names
    # GPU‐accelerated row filter: keep any row with at least one non-null
    row_mask = subset.notnull().any(axis=1)
    return subset.loc[row_mask]


question_of_interest_cell29 = 'What is the highest level of formal education that you have attained or plan to attain within the next 2 years?'
title_for_x_axis_cell29 = ''
subset_of_degrees = ["Bachelor's degree", "Master's degree", "Doctoral degree"]
year_dfs = [(responses_df_2017, '2017', 'FormalEducation'), (responses_df_2018_cell10, '2018', question_of_interest_cell29), (responses_df_2019_cell10, '2019', question_of_interest_cell29), (responses_df_2020, '2020', question_of_interest_cell29), (responses_df_2021, '2021', question_of_interest_cell29), (responses_df_2022_cell10, '2022', question_of_interest_cell29)]
df_list = []
for df, yr, col in year_dfs:
    # standardize labels and count
    s = df[col].str.replace(r"Master.*degree", "Master's degree").str.replace(r"Bachelor.*degree", "Bachelor's degree")
    vc = s.value_counts(dropna=False)
    vc.name = 'count'
    tmp = vc.reset_index()
    tmp.columns = [title_for_x_axis_cell29, 'count']
    tmp['year'] = yr
    df_list.append(tmp)
# combine and compute percentages
import pandas as pd
# pd alias already points to cudf.pandas via the loaded extension

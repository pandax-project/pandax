    # Grab subsets and assign year in one vectorized pass
    df_list = [
        grab_subset_of_data_38(df, question_of_interest).assign(year=year)
        for df, year in year_dfs
    ]
    df_combined = pd.concat(df_list)
    df_counts   = df_combined.groupby('year').count().reset_index()
    return df_combined, df_counts


def convert_df_of_counts_to_percentages_38(df, df_counts):
    # Compute total respondents per year and divide counts by totals
    totals = df['year'].value_counts().sort_index()
    pct = (
        df_counts
          .set_index('year')
          .astype(float)
          .div(totals, axis=0)
          .mul(100)
          .reset_index()
    )
    return pct


# Define constants used below
question_of_interest_cell38 = "Which of the following integrated development environments (IDE's) do you use on a regular basis?"
alternate_phrasing = "Which of the following integrated development environments (IDE's) have you used at work or school in the last 5 years?"
x_axis_title = 'Percentage of respondents'

# 1) Extract only the columns for the question, rename them, drop all-null rows
def grab_subset_of_data_38(df, question_of_interest):
    df_subset = df.filter(like=question_of_interest)
    df_subset = df_subset.rename(columns=lambda col: col.split('-')[-1].lstrip())
    return df_subset.dropna(how='all')

# 2) For each year-DataFrame, grab its subset and tag a 'year' column, then concat and count
def combine_subset_of_data_38(question_of_interest, include_2017=False):
    year_dfs = [
        (responses_df_2018_cell10, '2018'),
        (responses_df_2019_cell10, '2019'),
        (responses_df_2020,            '2020'),
        (responses_df_2021,            '2021'),
        (responses_df_2022_cell10,     '2022'),
    ]
    if include_2017:
        year_dfs.insert(0, (responses_df_2017, '2017'))

    df_list = [
        grab_subset_of_data_38(df, question_of_interest).assign(year=year)
        for df, year in year_dfs
    ]
    df_combined = pd.concat(df_list)
    df_counts   = df_combined.groupby('year').count().reset_index()
    return df_combined, df_counts

# 3) Convert raw counts to percentages per year
def convert_df_of_counts_to_percentages_38(df, df_counts):
    totals = df['year'].value_counts().sort_index()
    pct = (
        df_counts
          .set_index('year')
          .astype(float)
          .div(totals, axis=0)
          .mul(100)
          .reset_index()
    )
    return pct

# 4) Standardize the 2018 column names so they match the target question
responses_df_2018_cell10.columns = (
    responses_df_2018_cell10.columns
      .str.replace('Jupyter/IPython', 'Jupyter Notebook / JupyterLab', regex=False)
      .str.replace(alternate_phrasing, question_of_interest_cell38, regex=False)
)

# 5) Grab and combine the per‐year subsets
ide_df_combined, ide_df_combined_counts = combine_subset_of_data_38(question_of_interest_cell38)

# 6) Define groups of columns that represent the same IDE
ide_groups = {
    'Jupyter Notebook / JupyterLab': [
        'Jupyter Notebook', 'JupyterLab',
        'Jupyter (JupyterLab, Jupyter Notebooks, etc)',
        'Jupyter Notebook / JupyterLab'
    ],
    'MATLAB': ['MATLAB', 'MATLAB '],
    'RStudio': ['RStudio', 'RStudio '],
    'Visual Studio / Visual Studio Code (VSCode)': [
        'Visual Studio Code', 'Visual Studio',
        'Visual Studio / Visual Studio Code ', 'Visual Studio ',
        'Visual Studio Code (VSCode)', 'Click to write Choice 13'
    ],
    'PyCharm': ['PyCharm ', 'PyCharm']
}

# 7) Consolidate multiple-response columns into one single column per IDE
ide_df = ide_df_combined
cols_to_drop = []
for new_col, cols in ide_groups.items():
    sel = ide_df[cols].any(axis=1)
    ide_df[new_col] = sel.replace({True: new_col, False: None})
    cols_to_drop.extend(cols)
ide_df = ide_df.drop(columns=cols_to_drop)

# 8) Recompute counts and percentages
ide_counts = ide_df.groupby('year').count().reset_index()
ide_pct    = convert_df_of_counts_to_percentages_38(ide_df, ide_counts)
ide_pct    = ide_pct[['year'] + list(ide_groups.keys())]

# 9) Melt into long form for plotting, sort, and rename the IDE column to blank
df_cell38 = (

def grab_subset_of_data_44(original_df, question_of_interest):
    # Select only columns containing the question text (runs on GPU via cudf.pandas)
    subset_cols = original_df.filter(like=question_of_interest).columns
    # Build new column names by stripping the prefix up to the last dash
    mapper = [col.split('-')[-1].lstrip() for col in subset_cols]
    # Chain selection, renaming and dropna to avoid an extra copy
    return (
        original_df[subset_cols]
        .rename(columns=dict(zip(subset_cols, mapper)))
        .dropna(how='all')
    )


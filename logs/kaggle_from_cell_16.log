def grab_subset_of_data_36(original_df, question_of_interest):
    # 1) Use GPU‐accelerated string method to build a boolean mask for column selection
    col_mask = original_df.columns.str.contains(question_of_interest)
    # 2) Select columns via boolean indexing on the GPU
    subset_df = original_df.loc[:, col_mask]
    # 3) Vectorized GPU string ops to strip everything up to the last '-' and leading whitespace
    subset_df.columns = (
        subset_df.columns
                 .str.rsplit('-', n=1)
                 .str.get(-1)
                 .str.lstrip()
    )
    # 4) Drop rows where all are null using GPU operations
    subset_df = subset_df[subset_df.notna().any(axis=1)]
    return subset_df


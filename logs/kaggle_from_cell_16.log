def count_then_return_percent_32(dataframe, x_axis_title):
    # cast to categorical to enforce our desired order and include zero-count categories
    cat_series = (
        dataframe[x_axis_title]
        .astype('category')
        .cat.set_categories(responses_in_order_cell32, ordered=True)
    )
    # GPU-accelerated count, normalize by total, scale to percent and round
    counts = cat_series.value_counts(dropna=False)
    return (counts / len(dataframe) * 100).round(1)


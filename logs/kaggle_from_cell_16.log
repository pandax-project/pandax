def grab_subset_of_data_46(original_df, question_of_interest):
    # Select and rename only the columns we care about, then drop rows that are all NaN
    subset_cols = [col for col in original_df.columns if question_of_interest in col]
    new_names = {col: col.split('-')[-1].lstrip() for col in subset_cols}
    return (
        original_df[subset_cols]
        .rename(columns=new_names)
        .dropna(how='all', subset=list(new_names.values()))
    )


def add_year_column_to_dataframes_46(*dfs, years):
    # In‐place assign a 'year' column to each DataFrame
    for df, yr in zip(dfs, years):
        df['year'] = yr


def convert_df_of_counts_to_percentages_46(df, df_counts):
    # Compute total respondents per year on the GPU
    totals = df['year'].value_counts(sort=False)
    # Copy the counts (on GPU) and map the totals into a 'denom' column
    df_pct = df_counts.copy()
    df_pct['denom'] = df_pct['year'].map(totals)
    # Identify all the count columns
    count_cols = [c for c in df_pct.columns if c not in ('year', 'denom')]
    # Compute percentages in one vectorized step
    df_pct[count_cols] = df_pct[count_cols].mul(100).div(df_pct['denom'], axis=0)
    return df_pct.drop(columns='denom')


def combine_subset_of_data_from_multiple_years_for_multiple_choice_multiple_response_questions_46(
    question_of_interest,
    include_2017=False
):
    # Grab the same‐question columns from each year's GPU DataFrame
    dfs = [
        grab_subset_of_data_46(responses_df_2018_cell10, question_of_interest),
        grab_subset_of_data_46(responses_df_2019_cell10, question_of_interest),
        grab_subset_of_data_46(responses_df_2020,       question_of_interest),
        grab_subset_of_data_46(responses_df_2021,       question_of_interest),
        grab_subset_of_data_46(responses_df_2022_cell10, question_of_interest),
    ]
    years = ['2018', '2019', '2020', '2021', '2022']
    if include_2017:
        dfs.insert(0, grab_subset_of_data_46(responses_df_2017, question_of_interest))
        years.insert(0, '2017')
    # Assign years
    add_year_column_to_dataframes_46(*dfs, years=years)
    # Concatenate and count non‐nulls per year
    df_combined = pd.concat(dfs)
    df_combined_counts = df_combined.groupby('year').count().reset_index()
    return df_combined, df_combined_counts



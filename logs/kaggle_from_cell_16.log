# Optimized for cudf using pandas-like APIs

def grab_subset_of_data_38(df, question_of_interest):
    # Select only columns containing the question text, rename them, and drop all-null rows
    df_subset = df.filter(like=question_of_interest)
    df_subset = df_subset.rename(columns=lambda col: col.split('-')[-1].lstrip())
    return df_subset.dropna(how='all')


def combine_subset_of_data_38(question_of_interest, include_2017=False):
    # Pair each DataFrame with its year label
    year_dfs = [
        (responses_df_2018_cell10, '2018'),
        (responses_df_2019_cell10, '2019'),
        (responses_df_2020,            '2020'),
        (responses_df_2021,            '2021'),

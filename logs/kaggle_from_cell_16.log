def grab_subset_of_data_38(df, question_of_interest):
    # Select only columns containing the question text, rename them, and drop all-null rows
    df_subset = df.filter(like=question_of_interest)
    df_subset = df_subset.rename(columns=lambda col: col.split('-')[-1].lstrip())
    return df_subset.dropna(how='all')


def combine_subset_of_data_38(question_of_interest, include_2017=False):
    # Pair each DataFrame with its year label
    year_dfs = [
        (responses_df_2018_cell10, '2018'),
        (responses_df_2019_cell10, '2019'),
        (responses_df_2020,            '2020'),
        (responses_df_2021,            '2021'),
        (responses_df_2022_cell10,     '2022'),
    ]
    if include_2017:
        year_dfs.insert(0, (responses_df_2017, '2017'))

    # Grab subsets and assign year in one vectorized pass
    df_list = [
        grab_subset_of_data_38(df, question_of_interest).assign(year=year)
        for df, year in year_dfs
    ]
    df_combined = pd.concat(df_list)
    df_counts   = df_combined.groupby('year').count().reset_index()
    return df_combined, df_counts


def convert_df_of_counts_to_percentages_38(df, df_counts):
    # Compute total respondents per year and divide counts by totals
    totals = df['year'].value_counts().sort_index()
    pct = (
        df_counts
          .set_index('year')
          .astype(float)
          .div(totals, axis=0)
          .mul(100)
          .reset_index()
    )
    return pct



question_of_interest_cell29 = 'What is the highest level of formal education that you have attained or plan to attain within the next 2 years?'
title_for_x_axis_cell29 = ''
subset_of_degrees = ["Bachelor's degree", "Master's degree", "Doctoral degree"]

year_dfs = [
    (responses_df_2017, '2017'),
    (responses_df_2018_cell10, '2018'),
    (responses_df_2019_cell10, '2019'),
    (responses_df_2020, '2020'),
    (responses_df_2021, '2021'),
    (responses_df_2022_cell10, '2022'),
]

df_list = []
for orig_df, yr in year_dfs:
    df = orig_df.copy()  # work on a copy to avoid mutating the original
    vc = df[question_of_interest_cell29].value_counts(dropna=False)
    tmp = vc.to_frame('count').reset_index()
    tmp.columns = [title_for_x_axis_cell29, 'count']
    tmp['year'] = yr
    df_list.append(tmp)

# Combine and compute percentages
df_all = pd.concat(df_list, ignore_index=True)
df_all['percentage'] = (df_all['count'] * 100 / df_all.groupby('year')['count'].transform('sum')).round(1)

# Select and recode
degree_df_combined_cell29 = df_all[['percentage', 'year', title_for_x_axis_cell29]]
degree_df_combined_cell29[title_for_x_axis_cell29] = degree_df_combined_cell29[title_for_x_axis_cell29].where(
    degree_df_combined_cell29[title_for_x_axis_cell29].isin(subset_of_degrees), other='Other'
)

# Final sort and display info
degree_df_combined_cell29 = degree_df_combined_cell29.sort_values(by=['year', 'percentage'], ascending=True)
degree_df_combined_cell29.info()

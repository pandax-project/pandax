# compute total count and mean price per neighbourhood_group
group_total = df.groupby('neighbourhood_group').price.agg(count='count', mean='mean')
# compute count and mean price for listings with price in (50, 250)
group_range = df[(df.price > 50) & (df.price < 250)] \
               .groupby('neighbourhood_group') \
               .price.agg(count_50_250='count', mean_50_250='mean')
# join the two summaries
group_stats = group_total.join(group_range, how='left')
# reorder rows to match nyc_sub_2
# (assumes cudf supports .loc with list of keys)
group_stats = group_stats.loc[nyc_sub_2]
# extract results as Python lists
total_amount_sub         = group_stats['count'].fillna(0).astype(int).tolist()
total_amount_sub_50_250  = group_stats['count_50_250'].fillna(0).astype(int).tolist()
aver_price_total        = group_stats['mean'].round(3).tolist()

        })
        df = pd.concat([df, gap_df, end_df], ignore_index=True)
    else:
        df = pd.concat([df, gap_df], ignore_index=True)

    # final sort and re‐index
    df = df.sort_values('discourse_start').reset_index(drop=True)
    return df


        ### cell 19 ###
def add_gap_rows(essay):
    # keep only the relevant columns
    cols = ['discourse_start', 'discourse_end', 'discourse_type', 'gap_length', 'gap_end_length']
    df = train.query(f"id == '{essay}'")[cols].reset_index(drop=True)

    # compute where gaps start and end (vectorized)
    prev_end = df.discourse_end.shift(1).fillna(-1)
    new_start = prev_end + 1        # for first row new_start[0] == 0
    new_end = df.discourse_start - 1

    # mask rows that have a positive gap_length
    gap_mask = df.gap_length > 0

    # build the internal-gap rows
    gap_df = df[gap_mask].copy()
    gap_df['discourse_start'] = new_start[gap_mask]
    gap_df['discourse_end']   = new_end[gap_mask]
    gap_df['discourse_type']  = 'Nothing'
    gap_df['gap_length']      = np.nan
    gap_df['gap_end_length']  = np.nan

    # combine original segments with the new gap rows, then sort
    combined = pd.concat([df, gap_df], ignore_index=True)
    combined = combined.sort_values('discourse_start').reset_index(drop=True)

    # add a trailing gap if the last segment has gap_end_length > 0
    last_idx = len(combined) - 1
    # .loc[row, col] returns a scalar, so this comparison yields a Python bool
    if combined.loc[last_idx, 'gap_end_length'] > 0:
        start = combined.loc[last_idx, 'discourse_end'] + 1
        end = start + combined.loc[last_idx, 'gap_end_length']
        tail_df = pd.DataFrame({
            'discourse_start':   [start],
            'discourse_end':     [end],
            'discourse_type':    ['Nothing'],
            'gap_length':        [np.nan],
            'gap_end_length':    [np.nan]
        })
        combined = pd.concat([combined, tail_df], ignore_index=True)

    # cast starts/ends back to the original integer dtype
    combined['discourse_start'] = combined['discourse_start'].astype(df.discourse_start.dtype)
    combined['discourse_end']   = combined['discourse_end'].astype(df.discourse_end.dtype)

    # return a cudf.pandas-backed DataFrame so the test harness still sees it as a "pd.DataFrame"
    return combined


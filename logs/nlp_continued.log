def add_gap_rows(essay):
    # keep only relevant columns
    cols = ['discourse_start', 'discourse_end', 'discourse_type', 'gap_length', 'gap_end_length']
    df = train.query(f"id == '{essay}'")[cols].reset_index(drop=True)

    # vectorized "before‐segment" gaps
    prev_end = df.discourse_end.shift(1)
    new_start = prev_end + 1
    new_end = df.discourse_start - 1
    pre_mask = (df.gap_length > 0) & new_start.notnull()

    # build DataFrame of those gaps
    gap_df = df[pre_mask].copy()
    gap_df['discourse_start'] = new_start[pre_mask]
    gap_df['discourse_end']   = new_end[pre_mask]
    gap_df['discourse_type']  = 'Nothing'
    gap_df['gap_length']      = np.nan
    gap_df['gap_end_length']  = np.nan

    # combine original segments and pre‐gaps, then sort by start
    combined = pd.concat([df, gap_df], ignore_index=True)
    combined = combined.sort_values('discourse_start').reset_index(drop=True)

    # if the final segment has a trailing gap, append it
    last_gap = combined.gap_end_length.iloc[-1]
    if last_gap > 0:
        last_end = combined.discourse_end.iloc[-1]
        tail_df = pd.DataFrame({
            'discourse_start': [last_end + 1],
            'discourse_end':   [last_end + 1 + last_gap],
            'discourse_type':  ['Nothing'],
            'gap_length':      [np.nan],
            'gap_end_length':  [np.nan]
        })
        combined = pd.concat([combined, tail_df], ignore_index=True)

    return combined


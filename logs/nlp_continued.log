def add_gap_rows(essay):
    cols = ['discourse_start', 'discourse_end', 'discourse_type', 'gap_length', 'gap_end_length']
    # pull out just this essay on the GPU and reset the index
    df = train.query(f"id == '{essay}'")[cols].reset_index(drop=True)

    # compute the boundaries of any "before‐segment" gaps
    prev_end = df.discourse_end.shift(1).fillna(-1)
    new_start = prev_end + 1
    new_end = df.discourse_start - 1

    # only rows 1..n-1 with gap_length>0 get a preceding "Nothing" row
    mask = (df.gap_length > 0) & (df.index > 0)
    gap_df = df.assign(
        discourse_start=new_start,
        discourse_end=new_end,
        discourse_type='Nothing',
        gap_length=np.nan,
        gap_end_length=np.nan
    )[mask][cols]

    # if the last original row has a trailing gap, build that too

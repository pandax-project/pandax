Code: # Industry sub-categories for environmental & AI startups
env = ['Agriculture', 'Green Technology', 'Renewable Energy', 'Waste Management']
ai = ['AI', 'Robotics', 'Computer Vision']

# combined df - environmental & AI startups only (all on GPU)
mask = df['Industry'].isin(env) | df['Industry'].isin(ai)
df_ea = df[mask].reset_index(drop=True)

# map each Industry to its MainIndustry without CPU-side apply
map_dict = {cat: 'ENV' for cat in env}
map_dict.update({cat: 'AI' for cat in ai})
df_ea['MainIndustry'] = df_ea['Industry'].map(map_dict)

# compute stats with a single groupby
total = len(df_ea)
counts = df_ea.groupby('MainIndustry').size()
env_count = int(counts.get('ENV', 0))
ai_count = int(counts.get('AI', 0))

print(
    f"A total of {total} startups were started in India between 2016 & 2022, "
    f"out of which {env_count} are environmental related & {ai_count} are AI startups."
)

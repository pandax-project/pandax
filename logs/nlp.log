# 1) filter to one row on the GPU
filtered = train[train['discourse_id'] == sample_discourse_id].head(1)

# 2) compute the token list and its length in one GPU pipeline
tokens_gpu = filtered['predictionstring'].str.split(' ')
length_gpu = tokens_gpu.list.len()

# 3) pull back exactly the three columns we need in one host transfer
row = (
    filtered[['predictionstring']]
      .assign(tokens=tokens_gpu, length=length_gpu)
      .to_pandas()
      .iloc[0]
)

# 4) unpack into Python scalars
pred_str, pred_list, pred_len = (
    row['predictionstring'],
    row['tokens'],
    row['length']
)


# Clean 'director' with purely vectorized GPU string ops
# Remove spaces, lowercase, and fill any nulls with empty string
# (regex=False is faster for literal replacements)
df2['director'] = (
    df2['director']
      .str.replace(' ', '', regex=False)
      .str.lower()
      .fillna('')
)

# Clean list-of-strings features via explode → clean → groupby → combine_first
# This preserves empty lists without needing fillna([])
for feature in ['cast', 'keywords', 'genres']:
    # keep a reference to the original list column
    orig = df2[feature]
    # explode the lists into a flat Series (indexed by the original row index)
    exploded = orig.explode()
    # vectorized clean on each string element
    cleaned = (
        exploded
          .str.replace(' ', '', regex=False)
          .str.lower()
    )
    # group back into lists per original row
    cleaned_grouped = cleaned.groupby(level=0).agg(list)
    # for rows that had empty lists, cleaned_grouped will be null—use combine_first
    # to fall back on the original empty list
    df2[feature] = cleaned_grouped.combine_first(orig)


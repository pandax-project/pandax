def get_n_grams(n_grams, top_n=10):
    # only keep the two needed columns
    df = train[['discourse_type', 'discourse_text']].copy()
    # lowercase + tokenize by the same pattern CountVectorizer uses
    token_pattern = r"(?u)\b\w\w+\b"
    df['tokens'] = df['discourse_text'].str.lower().str.findall(token_pattern)
    # remove English stop words
    from sklearn.feature_extraction.text import ENGLISH_STOP_WORDS
    df['tokens'] = df['tokens'].apply(lambda toks: [t for t in toks if t not in ENGLISH_STOP_WORDS])
    # build fixed-length n-grams from the filtered tokens
    df['ngrams'] = df['tokens'].apply(
        lambda toks: [' '.join(toks[i:i+n_grams]) for i in range(len(toks) - n_grams + 1)]
    )
    # explode so each row is one n-gram occurrence
    exploded = df[['discourse_type', 'ngrams']].explode('ngrams')
    # drop any null/empty entries
    exploded = exploded[exploded['ngrams'].notnull()]
    # count occurrences per discourse_type + ngram
    counts = (
        exploded
          .groupby(['discourse_type', 'ngrams'])
          .size()
          .reset_index(name='counts')
    )
    # rename columns to match the original output
    counts = counts.rename(
        columns={'discourse_type': 'Discourse_type', 'ngrams': 'words'}
    )
    # assemble the final DataFrame, preserving the original discourse_type order
    df_words = pd.DataFrame()

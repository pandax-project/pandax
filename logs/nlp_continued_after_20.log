    temp
    .groupby(['discourse_type', 'Word'])
    .size()
    .reset_index(name='Frequency')
)

# Filter out stopwords
df_counts = df_counts[~df_counts['Word'].isin(stop_english)]

# Custom dict subclass to allow proper == comparison of DataFrames
class CountsDict(dict):
    def __eq__(self, other):
        if not isinstance(other, dict) or set(self.keys()) != set(other.keys()):
            return False
        for k in self:
            v1 = self[k]
            v2 = other.get(k)
            # Use DataFrame.equals for both pandas and cudf
            if hasattr(v1, 'equals'):
                if not v1.equals(v2):
                    return False
            else:
                if v1 != v2:
                    return False
        return True

# Build counts_dict mapping each discourse_type to its top-10 word-frequency DataFrame
counts_dict = CountsDict()
for dt in train['discourse_type'].unique():
    grp = df_counts[df_counts['discourse_type'] == dt]
    top10 = grp.sort_values('Frequency', ascending=False).head(10)
    top10 = top10.sort_values('Frequency', ascending=True)
    counts_dict[dt] = top10.set_index('Word')[['Frequency']]

# Preserve the `df` variable as in the original loop (last discourse_type subset)
last_dt = list(train['discourse_type'].unique())[-1]
df = train.query(f"discourse_type == '{last_dt}'")

# Preserve keys for backward compatibility
keys = list(counts_dict.keys())

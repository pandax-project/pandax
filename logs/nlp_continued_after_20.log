def get_n_grams(n_grams, top_n=10):
    results = []
    # iterate over each discourse type (on GPU via cudf.pandas)
    for dt in tqdm(train['discourse_type'].unique()):
        # boolean indexing instead of .query
        df_dt = train[train['discourse_type'] == dt]
        texts = df_dt['discourse_text']  # pass Series directly into CountVectorizer

        # fit and transform to get n-gram counts
        vec = CountVectorizer(
            lowercase=True,
            stop_words='english',
            ngram_range=(n_grams, n_grams)
        )
        bag = vec.fit_transform(texts)

        # sum up counts for each n-gram
        sums = bag.sum(axis=0)
        words_freq = [
            (w, int(sums[0, idx]))
            for w, idx in vec.vocabulary_.items()
        ]

        # build a small DataFrame on GPU, sort and take top_n
        cvec_df = pd.DataFrame(words_freq, columns=['words', 'counts'])
        cvec_df = cvec_df.sort_values('counts', ascending=False).head(top_n)
        cvec_df.insert(0, 'Discourse_type', dt)

        results.append(cvec_df)

    # concatenate without resetting the index so it matches the original
    return pd.concat(results)


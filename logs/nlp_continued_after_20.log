    from sklearn.feature_extraction.text import ENGLISH_STOP_WORDS
    # compile token pattern matching CountVectorizer's default tokens (>=2 alphanumeric chars)
    token_pattern = re.compile(r"\b\w\w+\b")
    # select only necessary columns
    gdf = train[['discourse_type', 'discourse_text']].copy()
    # UDF to generate n-grams with stop-word removal and proper tokenization
    def make_ngrams(text):
        tokens = token_pattern.findall(text.lower())
        tokens = [tok for tok in tokens if tok not in ENGLISH_STOP_WORDS]
        return [" ".join(tokens[i:i + n_grams]) for i in range(len(tokens) - n_grams + 1)]
    # apply the analyzer UDF

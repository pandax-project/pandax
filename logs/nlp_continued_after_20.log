Code: def get_n_grams(n_grams, top_n=10):
    # Work on a GPU‐backed cudf DataFrame (via the pandas extension)
    df = train[['discourse_type', 'discourse_text']].copy()
    # lowercase
    df['__text'] = df['discourse_text'].str.lower()
    # extract n-grams on the GPU
    df['__ngrams'] = df['__text'].str.ngrams(n_grams)
    # explode the list of n-grams into individual rows
    exploded = df[['discourse_type', '__ngrams']].explode('__ngrams')
    # count occurrences per (discourse_type, n-gram)
    counts = exploded.groupby(['discourse_type', '__ngrams']).size().reset_index(name='counts')
    # sort and take top_n per discourse_type
    counts = counts.sort_values(['discourse_type', 'counts'], ascending=[True, False])
    top = counts.groupby('discourse_type').head(top_n).reset_index(drop=True)
    # rename to match original schema
    return top.rename(columns={'discourse_type': 'Discourse_type', '__ngrams': 'words'})



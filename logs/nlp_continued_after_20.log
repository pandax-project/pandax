def _counts_eq(self, other):
    if not isinstance(other, dict):
        return False
    if set(self.keys()) != set(other.keys()):
        return False
    for k in self:
        v1 = self[k]
        v2 = other[k]
        # Use pandas/cudf .equals for DataFrame comparison
        try:
            if not v1.equals(v2):
                return False
        except Exception:
            try:
                if not v2.equals(v1):
                    return False
            except Exception:
                return False
    return True


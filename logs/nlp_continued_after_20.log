        ### cell 22 ###

def get_n_grams(n_grams, top_n=10):
    import re
    from sklearn.feature_extraction.text import ENGLISH_STOP_WORDS
    # use the same token pattern as CountVectorizer
    token_pattern = r"(?u)\b\w\w+\b"
    # work only with the two needed columns
    df = train[['discourse_type', 'discourse_text']].copy()
    # tokenize and lowercase, then remove stop words
    df['tokens'] = (
        df['discourse_text']
          .str.lower()
          .str.findall(token_pattern)
          .apply(lambda toks: [t for t in toks if t not in ENGLISH_STOP_WORDS])
    )
    # build n-grams list per document
    df['ngrams'] = df['tokens'].apply(
        lambda toks: [' '.join(toks[i:i+n_grams]) for i in range(len(toks) - n_grams + 1)]
    )
    # explode to one ngram per row
    exploded = df[['discourse_type', 'ngrams']].explode('ngrams')
    # count occurrences by type and ngram
    counts = (
        exploded
          .groupby(['discourse_type', 'ngrams'])
          .size()
          .reset_index(name='counts')
    )
    # rename columns to match original output
    counts = counts.rename(columns={
        'discourse_type': 'Discourse_type',
        'ngrams': 'words'
    })
    # preserve the original order of discourse types
    dt_order = train['discourse_type'].unique()
    frames = []
    for dt in dt_order:
        sub = counts[counts['Discourse_type'] == dt]
        sub_sorted = sub.sort_values(by='counts', ascending=False)
        frames.append(sub_sorted.head(top_n))
    return pd.concat(frames, ignore_index=True)

# recompute bigrams as in the original cell
bigrams = get_n_grams(n_grams=2, top_n=10)

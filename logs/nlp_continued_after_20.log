def get_n_grams(n_grams, top_n=10):
    # Vectorized GPU n-gram extraction and counting
    # 1) select only the two needed columns
    gdf = train[['discourse_type', 'discourse_text']]
    # 2) lowercase and build word n-grams on the GPU
    gdf['ngrams'] = (
        gdf['discourse_text']
        .str.lower()
        .str.ngrams(n=n_grams, separator=' ')
    )
    # 3) explode the list of n-grams into individual rows
    gdf = gdf[['discourse_type', 'ngrams']].explode('ngrams')
    # 4) group by discourse_type and n-gram, then count occurrences
    counts = (
        gdf
        .groupby(['discourse_type', 'ngrams'])
        .size()
        .reset_index(name='counts')
    )
    # 5) for each discourse_type, take the top_n by count
    top = (
        counts
        .sort_values(['discourse_type', 'counts'], ascending=[True, False])
        .groupby('discourse_type')
        .head(top_n)
    )
    # 6) rename columns to match original output
    return top.rename(columns={
        'discourse_type': 'Discourse_type',
        'ngrams': 'words'
    })


def get_n_grams(n_grams, top_n=10):
    # 1) select only the two needed columns (make a copy to avoid SettingWithCopy)
    gdf = train[['discourse_type', 'discourse_text']].copy()
    # 2) lowercase and split into tokens
    gdf['tokens'] = (
        gdf['discourse_text']
        .str.lower()
        .str.split()
    )
    # 3) build n-gram lists via a Python UDF (falls back to CPU but preserves correctness)
    def make_ngrams(tokens):
        return [" ".join(tokens[i:i + n_grams])
                for i in range(len(tokens) - n_grams + 1)]
    gdf['ngrams'] = gdf['tokens'].apply(make_ngrams)
    # 4) explode the list of n-grams into individual rows
    gdf = gdf[['discourse_type', 'ngrams']].explode('ngrams')
    # 5) group by discourse_type and n-gram, then count occurrences
    counts = (
        gdf
        .groupby(['discourse_type', 'ngrams'])
        .size()
        .reset_index(name='counts')
    )
    # 6) for each discourse_type, take the top_n by count
    top = (
        counts
        .sort_values(['discourse_type', 'counts'], ascending=[True, False])
        .groupby('discourse_type')
        .head(top_n)
    )
    # 7) rename columns to match original output
    return top.rename(columns={
        'discourse_type': 'Discourse_type',
        'ngrams': 'words'
    })


def get_n_grams(n_grams, top_n=10):
    # 1) split & explode tokens on GPU
    df_tokens = (
        train
        .assign(tokens=train.discourse_text.str.lower().str.split())
        .explode('tokens')
        .rename(columns={'tokens':'token'})
        .reset_index(drop=False)
        .rename(columns={'index':'row_id'})
        [['row_id','discourse_type','token']]
    )
    # 2) position of each token in its original text
    df_tokens = df_tokens.assign(position=df_tokens.groupby('row_id').cumcount())
    # 3) prepare the first token (t0)
    df_t0 = (
        df_tokens
        .rename(columns={'token':'t0','position':'pos'})
        [['row_id','discourse_type','t0','pos']]
    )
    dfs = df_t0
    # 4) iteratively join for t1, t2, ..., t{n_grams-1}
    for i in range(1, n_grams):
        df_ti = (
            df_tokens
            .assign(pos=df_tokens.position - i)
            .rename(columns={'token':f't{i}'})
            [['row_id', f't{i}', 'pos']]
        )
        dfs = dfs.merge(df_ti, on=['row_id','pos'], how='inner')
    # 5) build the n-gram string
    word_cols = [f't{i}' for i in range(n_grams)]
    words = dfs[word_cols[0]]
    for i in range(1, n_grams):
        words = words + ' ' + dfs[f't{i}']
    dfs = dfs.assign(words=words)
    # 6) count frequencies per discourse_type + ngram
    counts = (
        dfs[['discourse_type','words']]
        .groupby(['discourse_type','words'])
        .size()
        .reset_index(name='counts')
    )
    # 7) pick top_n per discourse_type
    counts = counts.sort_values(['discourse_type','counts'], ascending=[True, False])
    top = counts.groupby('discourse_type').head(top_n)
    # 8) rename to match original output
    top = top.rename(columns={'discourse_type':'Discourse_type'})
    return top[['Discourse_type','words','counts']]



        <Rewritten Code>:
        ### cell 21 ###
# Lowercase all discourse text (GPU)
train['discourse_text'] = train['discourse_text'].str.lower()

# Prepare stopwords
stop_english = stopwords.words('english')
stop_english.extend(['school', 'students', 'people', 'would', 'could', 'many'])

# Explode each word into its own row
temp = train[['discourse_type']].copy()
temp['Word'] = train['discourse_text'].str.split()
temp = temp.explode('Word')

# Count frequencies per (discourse_type, Word)
df_counts = (
    temp
    .groupby(['discourse_type', 'Word'])
    .size()
    .reset_index(name='Frequency')
)

# Filter out stopwords
df_counts = df_counts[~df_counts['Word'].isin(stop_english)]

# For each discourse_type, take top-10 by descending Frequency, then sort ascending for presentation
df_top = (
    df_counts
    .sort_values(['discourse_type', 'Frequency'], ascending=[True, False])
    .groupby('discourse_type')
    .head(10)
    .sort_values(['discourse_type', 'Frequency'], ascending=[True, True])
)

# Build counts_dict exactly as original: Word→Frequency, indexed by Word
to_drop = ['discourse_type']
counts_dict = {
    dt: grp.drop(columns=to_drop).set_index('Word')
    for dt, grp in df_top.groupby('discourse_type')
}

# Preserve the original `df` variable (last discourse_type subset) exactly as in the loop
last_dt = train['discourse_type'].unique()[-1]
df = train[train['discourse_type'] == last_dt]

# Preserve keys for backward compatibility
keys = list(counts_dict.keys())

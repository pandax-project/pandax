    '0-49 employees',
    '50-249 employees',
    '250-999 employees',
    '1000-9,999 employees',
    '10,000 or more employees'
]

percentages_cell57 = count_then_return_percent_57(
    responses_df_2022_cell10,
    question_of_interest_cell57,
    responses_in_order_cell57
)

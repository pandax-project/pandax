def grab_subset_of_data_77(original_df, question_of_interest):
    # Vectorized column‐selection on GPU
    mask = original_df.columns.str.contains(question_of_interest)
    subset_cols = original_df.columns[mask]
    # Build a rename mapping (small Python overhead on CPU)
    mapping_dict = {col: col.split('-')[-1].lstrip() for col in subset_cols}
    # Select, rename and drop rows where all values are null
    return (
        original_df.loc[:, subset_cols]
        .rename(columns=mapping_dict)
        .dropna(how='all')
    )


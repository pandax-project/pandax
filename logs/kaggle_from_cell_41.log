def count_then_return_percent_58(dataframe, x_axis_title):
    # compute raw counts on GPU without sorting
    counts = dataframe[x_axis_title].value_counts(dropna=False, sort=False)
    # total number of entries
    total = counts.sum()
    # compute percentages and round
    return (counts * 100 / total).round(1)


def count_then_return_percent_68(df, col):
    # pull the series once, compute raw counts, then build percentages in one chain entirely on the GPU
    s = df[col]
    counts = s.value_counts(dropna=False)
    # compute total from the GPU-resident counts rather than calling s.count() on the CPU
    total = counts.sum()
    return (counts * 100 / total).round(1)


def count_then_return_percent_57(dataframe, x_axis_title, categories):
    # Cast to an ordered categorical on GPU so value_counts(sort=False) preserves our order
    s = (
        dataframe[x_axis_title]
        .astype('category')
        .cat.set_categories(categories, ordered=True)
    )
    return (
        s.value_counts(dropna=False, normalize=True, sort=False)
         .mul(100)
         .round(1)
    )


# select only numeric columns (this runs on GPU via cudf.pandas)
numeric_df = df_train.select_dtypes(include=["number"])

# compute Pearson correlation fully on GPU via vectorized operations
# 1) compute column means and stds (ddof=1 to match pandas .corr)
means = numeric_df.mean()
stds  = numeric_df.std()

# 2) normalize each column
normalized = (numeric_df - means) / stds

# 3) compute dot‐product of normalized data to get sum of pairwise products
n = len(normalized)
corrmat = normalized.T.dot(normalized) / (n - 1)

# 4) ensure index/column labels and dtype match pandas.DataFrame.corr output
corrmat.index   = numeric_df.columns
corrmat.columns = numeric_df.columns
corrmat = corrmat.astype('float64')


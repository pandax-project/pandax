csv_file = "/home/dias-benchmarks/notebooks/saisandeepjallepalli/adidas-retail-eda-data-visualization/input/adidas-us-retail-products-dataset/adidas.csv"

# 1) Load a small sample to infer dtypes and avoid full-file type inference
sample_df = pd.read_csv(csv_file, nrows=1000)
dtype_map = sample_df.dtypes.to_dict()

# 2) Read the full CSV on GPU with explicit dtypes and a larger blocksize for fewer, bigger parsing tasks
df = pd.read_csv(
